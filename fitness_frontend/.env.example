# Backend API (FastAPI) base URL (no trailing slash)
# Must match your backend URL and be included in BACKEND_CORS_ORIGINS on the backend.
NEXT_PUBLIC_BACKEND_API_BASE_URL=http://localhost:8000

# Firebase client config (request these from the orchestrator / user)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
